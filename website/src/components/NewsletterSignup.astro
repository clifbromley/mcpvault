---
const highlights = [
  'Release announcements before they hit npm',
  'Deep dives on new MCP client integrations',
  'Security tips for running MCP-Vault in production',
];
---

<section class="relative py-16 px-4 sm:px-6 lg:px-8">
  <div class="max-w-6xl mx-auto">
    <div class="newsletter-card bg-card/70 border border-border/60 rounded-2xl p-8 md:p-10 overflow-hidden relative">
      <div class="grid gap-12 md:grid-cols-2 md:items-center">
        <div>
          <p class="inline-flex items-center gap-2 text-xs uppercase tracking-[0.2em] text-muted-foreground">
            <span class="w-8 h-px bg-muted-foreground/40" aria-hidden="true"></span>
            Stay in the loop
          </p>
          <h2 class="mt-4 text-3xl font-semibold text-foreground">Ship updates to your inbox</h2>
          <p class="mt-3 text-muted-foreground leading-relaxed">
            Get a lightweight email whenever MCP-Vault ships a new release, adds a client configuration, or shares Obsidian automation recipes.
          </p>
          <ul class="mt-6 space-y-3 text-sm text-muted-foreground/90">
            {highlights.map((item) => (
              <li class="flex gap-3">
                <span class="inline-flex h-5 w-5 items-center justify-center rounded-full bg-accent/20 text-accent text-xs font-semibold">✓</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="bg-background/70 border border-border/50 rounded-xl p-6 shadow-2xl shadow-black/20">
          <form class="space-y-4" data-newsletter-form>
            <label class="block text-sm font-medium text-foreground" for="newsletter-email">
              Email address
            </label>
            <div class="flex flex-col gap-3 sm:flex-row">
              <input
                id="newsletter-email"
                type="email"
                name="email"
                placeholder="you@vaults.dev"
                required
                class="flex-1 rounded-lg border border-border/60 bg-[#050505]/60 px-4 py-3 text-foreground placeholder:text-muted-foreground/60 focus:border-accent focus:outline-none"
              />
              <button
                type="submit"
                class="inline-flex items-center justify-center rounded-lg bg-accent px-6 py-3 text-sm font-semibold text-black transition hover:bg-accent/90"
              >
                Join the list
              </button>
            </div>
            <p class="text-xs text-muted-foreground">Powered by Cloudflare. One-click unsubscribe in every email.</p>
            <p class="text-sm text-success hidden" data-newsletter-success>
              Welcome aboard. Check your inbox for a confirmation email.
            </p>
            <p class="text-sm text-error hidden" data-newsletter-error>
              Something went wrong. Please try again in a minute.
            </p>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  document.addEventListener('astro:page-load', () => {
    const form = document.querySelector('[data-newsletter-form]');
    if (!form) return;

    const successBanner = form.querySelector('[data-newsletter-success]');
    const errorBanner = form.querySelector('[data-newsletter-error]');
    const submitBtn = form.querySelector('button[type="submit"]');

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      if (!submitBtn) return;

      const formData = new FormData(form);
      const email = formData.get('email');

      if (!email || typeof email !== 'string') {
        errorBanner?.classList.remove('hidden');
        return;
      }

      submitBtn.disabled = true;
      submitBtn.textContent = 'Adding…';
      successBanner?.classList.add('hidden');
      errorBanner?.classList.add('hidden');

      try {
        const res = await fetch('/api/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email }),
        });

        if (!res.ok) throw new Error('Failed request');
        const data = await res.json();
        if (!data?.success) throw new Error(data?.message || 'Failed');

        successBanner?.classList.remove('hidden');
        form.reset();
      } catch (err) {
        console.error(err);
        errorBanner?.classList.remove('hidden');
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Join the list';
      }
    });
  });
</script>

<style>
  .newsletter-card::after {
    content: '';
    position: absolute;
    inset: -20% auto auto -10%;
    width: 260px;
    height: 260px;
    background: radial-gradient(circle, rgba(144, 101, 234, 0.35), transparent 60%);
    pointer-events: none;
    filter: blur(10px);
  }

  @media (max-width: 768px) {
    .newsletter-card {
      padding: 2rem;
    }
  }
</style>
